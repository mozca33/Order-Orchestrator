# App
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=orders_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API de câmbio: AwesomeAPI (sem chave necessária)
# https://economia.awesomeapi.com.br
EXCHANGE_TIMEOUT_MS=5000

# CORS — origens permitidas separadas por vírgula (vazio = CORS desabilitado)
ALLOWED_ORIGINS=

# Rate limiting
THROTTLE_WEBHOOK_TTL_MS=60000
THROTTLE_WEBHOOK_LIMIT=100
THROTTLE_READ_TTL_MS=60000
THROTTLE_READ_LIMIT=300

# Queue job retry config
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_BACKOFF_DELAY_MS=2000

# Proteção do painel Bull Board (/queues)
# Em produção: obrigatório. Enviar header x-dashboard-secret: <valor>
# Em desenvolvimento: pode deixar vazio para acesso livre
QUEUE_DASHBOARD_SECRET=
