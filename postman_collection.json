{
  "info": {
    "name": "Order Orchestrator",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "order_id", "value": "" },
    { "key": "idem_uid", "value": "" },
    { "key": "queue_dashboard_secret", "value": "Super1Strong2And3Unique4Secret5Value6!" }
  ],
  "item": [
    {
      "name": "1. Webhook — Receber Pedido",
      "item": [
        {
          "name": "✅ Pedido válido em USD",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const uid = 'usd-' + Date.now();",
                  "pm.variables.set('uid', uid);",
                  "pm.collectionVariables.set('idem_uid', uid);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 202', () => pm.response.to.have.status(202));",
                  "pm.test('retorna accepted com order_id UUID', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('accepted');",
                  "  pm.expect(body.order_id).to.match(/^[0-9a-f-]{36}$/);",
                  "  pm.collectionVariables.set('order_id', body.order_id);",
                  "});",
                  "pm.test('resposta tem X-Request-ID', () => {",
                  "  pm.expect(pm.response.headers.get('x-request-id')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/webhooks/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"{{uid}}\",\n  \"customer\": { \"email\": \"ana@example.com\", \"name\": \"Ana\" },\n  \"items\": [{ \"sku\": \"ABC123\", \"qty\": 2, \"unit_price\": 59.9 }],\n  \"currency\": \"USD\",\n  \"idempotency_key\": \"{{uid}}\"\n}"
            }
          }
        },
        {
